---
// About page — intro + career timeline + skills + contact (Task #9, #10)
import BaseLayout from '../layouts/BaseLayout.astro';
import type { Career } from '../types';

// Skill categories data
interface SkillCategory {
  label: string;
  skills: string[];
}

// Contact link data
interface ContactLink {
  label: string;
  href: string;
  display: string;
  icon: string; // SVG path(s)
}

const skillCategories: SkillCategory[] = [
  { label: 'Engine', skills: ['Unreal Engine 5'] },
  { label: 'Language', skills: ['C++', 'C#', 'Blueprint'] },
  { label: 'System', skills: ['Gameplay Ability System', 'AI / Behavior Tree', 'Replication / Network', 'Animation / IK'] },
  { label: 'Tools', skills: ['Visual Studio', 'Rider', 'Git', 'Perforce'] },
];

const contactLinks: ContactLink[] = [
  {
    label: 'Email',
    href: 'mailto:saint5944@naver.com',
    display: 'saint5944@naver.com',
    icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  },
  {
    label: 'GitHub',
    href: 'https://github.com/Devsignerr',
    display: 'github.com/Devsignerr',
    icon: 'M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z',
  },
  {
    label: 'YouTube',
    href: 'https://youtu.be/GHh-IlVhQBs',
    display: 'YouTube',
    icon: 'M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z',
  },
];

// Career timeline data — placeholder content

const careers: Career[] = [
  {
    period: '2024 — 현재',
    dateFrom: '2024',
    title: '인디 게임 개발',
    company: 'Personal Project',
    description:
      '전투 액션 게임, 멀티플레이어 액션 게임 등 UE5 기반 인디 게임 개발. 기획·구현·테스트·튜닝 전 과정을 담당하며 게임 디자인 감각을 키움.',
    skills: ['UE5', 'C++', 'Multiplayer', 'Steam'],
    isCurrent: true,
  },
  {
    period: '2021.12 — 2024.03',
    dateFrom: '2021',
    dateTo: '2024',
    title: '클라이언트 프로그래머 (전투파트)',
    company: 'Npixel — 크로노 오디세이',
    description:
      'UE5 기반 MMORPG 크로노 오디세이의 전투 시스템 개발. 스킬 시스템, 부위 타격, 락온, Foot IK, 데미지 UI, 스킬 개발툴 등 전투 관련 핵심 콘텐츠 구현.',
    skills: ['UE5', 'C++', 'Blueprint', 'GAS'],
    isCurrent: false,
  },
];
---

<BaseLayout
  title="About — 허서행"
  description="게임 개발자 허서행의 자기소개와 경력 타임라인. Unreal Engine C++ 게임 클라이언트 프로그래머."
>

  <!-- ============================================================
       Page Header — terminal label + title
       ============================================================ -->
  <section class="px-4 pb-8 pt-20 sm:px-6 lg:px-8 lg:pt-28">
    <div class="mx-auto max-w-6xl">
      <p class="mb-3 font-mono text-xs tracking-widest text-accent/60 uppercase" aria-hidden="true">
        // about
      </p>

      <h1 class="font-mono text-3xl font-bold text-gray-100 sm:text-4xl lg:text-5xl">
        About
      </h1>

      <p class="mt-4 max-w-2xl font-mono text-sm leading-relaxed text-gray-400 sm:text-base">
        게임 개발을 업으로 삼고 있는 <span class="text-accent-light">Unreal Engine C++</span> 프로그래머입니다.
      </p>
    </div>
  </section>

  <!-- ============================================================
       Intro Section — avatar + profile + bio text
       ============================================================ -->
  <section id="about-section" class="px-4 pb-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">

      <!-- Profile card — stacks vertically on mobile, side-by-side on md+ -->
      <div class="flex flex-col gap-10 md:flex-row md:items-start md:gap-16">

        <!-- Avatar + identity block -->
        <div class="animate-on-scroll flex shrink-0 flex-col items-center text-center md:w-56 md:items-start md:text-left">

          <!-- Avatar placeholder — circular with accent border -->
          <div
            class="relative mb-5 flex h-28 w-28 items-center justify-center rounded-full border-2 border-accent bg-dark-200 shadow-glow"
            aria-hidden="true"
          >
            <!-- Outer glow ring -->
            <div class="absolute inset-0 rounded-full shadow-glow-lg opacity-40"></div>

            <!-- Initial letter -->
            <span class="font-mono text-4xl font-bold text-accent text-glow select-none">서</span>
          </div>

          <!-- Name -->
          <p class="font-mono text-lg font-bold text-gray-100">허서행</p>

          <!-- Title -->
          <p class="mt-1 font-mono text-sm font-medium text-accent-light">Game Client Programmer</p>

          <!-- One-liner -->
          <p class="mt-2 font-mono text-xs leading-relaxed text-gray-500">
            Unreal Engine C++ 게임 클라이언트 프로그래머
          </p>

          <!-- Decorative separator -->
          <div class="mt-5 h-px w-full max-w-[120px] bg-gradient-to-r from-transparent via-accent/40 to-transparent md:max-w-full" aria-hidden="true"></div>
        </div>

        <!-- Bio text block -->
        <div class="flex-1 space-y-5">
          <p class="animate-on-scroll font-mono text-sm leading-relaxed text-gray-400 sm:text-base" style="transition-delay: 80ms;">
            플레이어 시선에서 게임을 분석하고 더 큰 재미를 만들기 위해 타 직군과 끊임없이 소통하는 개발자입니다.
            구현 직후 게임을 가장 처음 플레이하는 유저라는 책임감으로 <span class="text-gray-200">기획자와 소통</span>하며
            게임의 밀도를 높이는 데 기여해 왔습니다.
          </p>

          <p class="animate-on-scroll font-mono text-sm leading-relaxed text-gray-400 sm:text-base" style="transition-delay: 160ms;">
            프로젝트 전체의 효율성을 위해 기획팀과 아트팀의 반복 업무를 줄이는
            <span class="text-accent-light">자동화 툴과 기능</span>을 제안하고 개발합니다.
            스킬 제작 툴 개선, Physics Body 데이터 자동 추출 등의 작업이 그 예입니다.
          </p>

          <p class="animate-on-scroll font-mono text-sm leading-relaxed text-gray-400 sm:text-base" style="transition-delay: 240ms;">
            <span class="text-gray-200">UE5 기반 MMORPG에서 2년 3개월간</span> 전투 시스템 개발 실무를 쌓고,
            이후 1년간 인디 게임 개발을 통해 '재미있는 게임'의 본질을 탐구했습니다.
            네트워크 동기화, 서버 권한 판정 등 <span class="text-accent-light">멀티플레이어 핵심 기술</span>도 직접 경험했습니다.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       Career Timeline Section
       ============================================================ -->
  <section id="career-section" class="px-4 pb-24 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">

      <!-- Section header -->
      <div class="mb-12">
        <p class="mb-3 font-mono text-xs tracking-widest text-accent/60 uppercase" aria-hidden="true">
          // career_timeline
        </p>
        <h2 class="font-mono text-2xl font-bold text-gray-100 sm:text-3xl">경력</h2>
      </div>

      <!-- Timeline — relative container for the vertical line -->
      <ol class="relative border-l-2 border-accent/20 pl-6 sm:pl-8 lg:pl-10" aria-label="경력 타임라인">

        {careers.map((career, index) => (
          <li
            class:list={[
              'career-item animate-on-scroll relative mb-10 last:mb-0',
            ]}
            style={`transition-delay: ${index * 120}ms;`}
          >

            <!-- Timeline dot — positioned on the vertical line -->
            <span
              class:list={[
                'absolute -left-[2.1rem] top-1.5 flex h-3 w-3 items-center justify-center rounded-full sm:-left-[2.65rem] lg:-left-[2.85rem]',
                career.isCurrent
                  ? 'bg-accent shadow-glow career-dot-pulse'
                  : 'bg-dark-300 border border-accent/40',
              ]}
              aria-hidden="true"
            ></span>

            <!-- Career card -->
            <article
              class:list={[
                'rounded-game border p-5 transition-all duration-300 sm:p-6',
                career.isCurrent
                  ? 'border-accent/40 bg-dark-100 shadow-glow-sm hover:shadow-glow'
                  : 'border-dark-300 bg-dark-100 hover:border-accent/30 hover:shadow-glow-sm',
              ]}
            >

              <!-- Period badge + current indicator -->
              <div class="mb-3 flex flex-wrap items-center gap-2">
                <time datetime={career.dateTo ? `${career.dateFrom}/${career.dateTo}` : career.dateFrom} class="font-mono text-xs font-medium tracking-wide text-accent/80">
                  {career.period}
                </time>

                {career.isCurrent && (
                  <span class="rounded-game bg-accent/20 px-2 py-0.5 font-mono text-xs font-medium text-accent-light border border-accent/30">
                    현재
                  </span>
                )}
              </div>

              <!-- Job title + company -->
              <h3 class="font-mono text-base font-bold text-gray-100 sm:text-lg">
                {career.title}
              </h3>
              <p class="mt-0.5 font-mono text-sm text-gray-500">
                @ {career.company}
              </p>

              <!-- Description -->
              <p class="mt-3 font-mono text-sm leading-relaxed text-gray-400">
                {career.description}
              </p>

              <!-- Skill tags -->
              <ul class="mt-4 flex flex-wrap gap-2" aria-label="사용 기술">
                {career.skills.map((skill) => (
                  <li>
                    <span class="rounded-game border border-dark-300 bg-dark-200 px-2.5 py-1 font-mono text-xs text-gray-400">
                      {skill}
                    </span>
                  </li>
                ))}
              </ul>

            </article>
          </li>
        ))}

      </ol>

    </div>
  </section>

  <!-- ============================================================
       Skills Section — categorized skill badges
       ============================================================ -->
  <section id="skills-section" class="px-4 pb-24 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">

      <!-- Section header -->
      <div class="mb-12">
        <p class="mb-3 font-mono text-xs tracking-widest text-accent/60 uppercase" aria-hidden="true">
          // skills
        </p>
        <h2 class="font-mono text-2xl font-bold text-gray-100 sm:text-3xl">스킬</h2>
      </div>

      <!-- Skill category grid — 1 col mobile, 2 col md+ -->
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        {skillCategories.map((category, catIndex) => (
          <div
            class="animate-on-scroll"
            style={`transition-delay: ${catIndex * 80}ms;`}
          >
            <!-- Category label -->
            <h3 class="mb-4 font-mono text-xs font-semibold tracking-widest text-accent/70 uppercase">
              {category.label}
            </h3>

            <!-- Badge list -->
            <ul class="flex flex-wrap gap-2" aria-label={`${category.label} 스킬 목록`}>
              {category.skills.map((skill) => (
                <li>
                  <span class="inline-block rounded-game border border-accent/20 bg-accent/10 px-3 py-1.5 font-mono text-xs font-medium text-gray-300 transition-all duration-200 hover:border-accent/50 hover:bg-accent/20 hover:text-accent-light hover:shadow-glow-sm">
                    {skill}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ============================================================
       Contact Section — CTA + social links
       ============================================================ -->
  <section id="contact-section" class="px-4 pb-32 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">

      <!-- Section header -->
      <div class="mb-8">
        <p class="mb-3 font-mono text-xs tracking-widest text-accent/60 uppercase" aria-hidden="true">
          // contact
        </p>
        <h2 class="font-mono text-2xl font-bold text-gray-100 sm:text-3xl">연락처</h2>
      </div>

      <!-- CTA text -->
      <p class="animate-on-scroll mb-10 max-w-xl font-mono text-sm leading-relaxed text-gray-400 sm:text-base">
        프로젝트 협업이나 채용에 관심이 있으시다면 연락주세요.
      </p>

      <!-- Contact link cards — 1 col mobile, 3 col md+ -->
      <ul class="grid grid-cols-1 gap-4 md:grid-cols-3" aria-label="연락처 링크">
        {contactLinks.map((link, linkIndex) => (
          <li
            class="animate-on-scroll"
            style={`transition-delay: ${linkIndex * 100}ms;`}
          >
            <a
              href={link.href}
              target={link.href.startsWith('mailto') ? undefined : '_blank'}
              rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
              class="group flex items-center gap-4 rounded-game border border-dark-300 bg-dark-200 p-5 transition-all duration-300 hover:border-accent/50 hover:bg-dark-100 hover:shadow-glow-sm"
              aria-label={`${link.label}: ${link.display}${link.href.startsWith('http') ? ' (새 탭에서 열림)' : ''}`}
            >
              <!-- Icon -->
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-game border border-dark-300 bg-dark-300 text-accent/60 transition-all duration-300 group-hover:border-accent/40 group-hover:text-accent" aria-hidden="true">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d={link.icon} />
                </svg>
              </span>

              <!-- Text -->
              <div class="min-w-0">
                <p class="font-mono text-xs font-semibold tracking-wider text-accent/70 uppercase">
                  {link.label}
                </p>
                <p class="mt-0.5 truncate font-mono text-sm text-gray-300 transition-colors duration-200 group-hover:text-accent-light">
                  {link.display}
                </p>
              </div>
            </a>
          </li>
        ))}
      </ul>

    </div>
  </section>

</BaseLayout>

<script>
  // ----------------------------------------------------------------
  // Scroll animation — re-initialised on every page load (including View Transitions)
  // ----------------------------------------------------------------

  function initAboutScroll() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const animatableElements = document.querySelectorAll<HTMLElement>('.animate-on-scroll');

    if (!prefersReducedMotion) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              (entry.target as HTMLElement).classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      animatableElements.forEach((el) => observer.observe(el));
    } else {
      // Reduced motion — make all elements immediately visible
      animatableElements.forEach((el) => el.classList.add('is-visible'));
    }
  }

  document.addEventListener('astro:page-load', initAboutScroll);
</script>

<style>
  /* Pulsing glow for the "current" timeline dot */
  .career-dot-pulse {
    animation: dotPulse 2.4s ease-in-out infinite;
  }

  @keyframes dotPulse {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(99, 102, 241, 0.6);
    }
    50% {
      box-shadow: 0 0 0 6px rgba(99, 102, 241, 0);
    }
  }

  /* prefers-reduced-motion — disable dot pulse */
  @media (prefers-reduced-motion: reduce) {
    .career-dot-pulse {
      animation: none;
    }
  }
</style>
