---

<section
  id="tech-stack-section"
  aria-label="기술 스택"
  class="relative px-4 py-20 sm:px-6 lg:px-8"
>
  <!-- Section top accent line -->
  <div
    class="absolute left-1/2 top-0 h-px w-24 -translate-x-1/2 bg-gradient-to-r from-transparent via-accent/50 to-transparent"
    aria-hidden="true"
  ></div>

  <div class="mx-auto max-w-6xl">

    <!-- Section header -->
    <header class="mb-12 flex flex-col items-start gap-3 sm:mb-16">
      <!-- Terminal-style label -->
      <p
        class="animate-on-scroll font-mono text-xs tracking-[0.3em] text-accent/60 uppercase"
        aria-hidden="true"
      >
        // tech_stack
      </p>

      <!-- Headline -->
      <div class="animate-on-scroll" style="transition-delay: 0.1s;">
        <h2 class="font-mono text-2xl font-bold text-gray-100 sm:text-3xl lg:text-4xl">
          기술 스택
        </h2>
        <p class="mt-2 font-mono text-sm text-gray-500">
          게임 개발에 사용하는 핵심 기술들입니다.
        </p>
      </div>
    </header>

    <!-- Category grid: 2-col mobile → 4-col lg -->
    <div class="grid grid-cols-2 gap-6 lg:grid-cols-4">
      {categories.map((category, catIndex) => (
        <div
          class="animate-on-scroll flex flex-col gap-3"
          style={`transition-delay: ${0.15 + catIndex * 0.08}s;`}
        >
          <!-- Category label -->
          <h3 class="font-mono text-xs font-semibold tracking-wider text-accent uppercase">
            {category.label}
          </h3>

          <!-- Tech item list -->
          <ul class="flex flex-col gap-2" aria-label={`${category.label} 기술 목록`}>
            {category.items.map((item) => (
              <li>
                <div
                  class="
                    group flex items-center gap-3
                    rounded-game border border-dark-300 bg-dark-200
                    px-3 py-2.5
                    transition-all duration-300
                    hover:border-accent/40 hover:shadow-glow-sm hover:scale-[1.02]
                  "
                >
                  <!-- Inline SVG icon -->
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox={item.viewBox ?? '0 0 24 24'}
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-4 w-4 shrink-0 text-accent/60 transition-colors duration-300 group-hover:text-accent"
                    aria-hidden="true"
                  >
                    <path d={item.iconPath} />
                  </svg>

                  <!-- Tech name -->
                  <span class="font-mono text-xs text-gray-300 leading-tight">
                    {item.name}
                  </span>
                </div>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  // Intersection Observer — re-initialised on every page load (including View Transitions)
  function initTechStackScroll() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const section = document.getElementById('tech-stack-section');

    if (!section) return;

    // Reset so items animate in when navigating back to this page
    section.querySelectorAll<HTMLElement>('.animate-on-scroll').forEach((el) => {
      el.classList.remove('is-visible');
    });

    if (!prefersReducedMotion) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              (entry.target as HTMLElement).classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      section.querySelectorAll('.animate-on-scroll').forEach((el) => {
        observer.observe(el);
      });
    } else {
      section.querySelectorAll<HTMLElement>('.animate-on-scroll').forEach((el) => {
        el.classList.add('is-visible');
      });
    }
  }

  document.addEventListener('astro:page-load', initTechStackScroll);
</script>
