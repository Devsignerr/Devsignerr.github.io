---
// Projects index page — full project grid with client-side tag filtering
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const allProjects = await getCollection('projects');

// Sort by date descending (newest first)
const sortedProjects = allProjects.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

// Extract unique tags from all projects, sorted alphabetically
const allTags = [...new Set(sortedProjects.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout
  title="Projects — Game Developer Portfolio"
  description="Unreal Engine C++ 게임 개발 프로젝트 모음. 전투 시스템, 절차적 생성, 셰이더 등 다양한 분야의 작업물."
>
  <!-- Page header -->
  <section class="px-4 pb-8 pt-20 sm:px-6 lg:px-8 lg:pt-28">
    <div class="mx-auto max-w-6xl">
      <!-- Terminal label -->
      <p class="mb-3 font-mono text-xs tracking-widest text-accent/60 uppercase" aria-hidden="true">
        // all_projects
      </p>

      <h1 class="font-mono text-3xl font-bold text-gray-100 sm:text-4xl lg:text-5xl">
        프로젝트
      </h1>

      <p class="mt-4 max-w-2xl font-mono text-sm leading-relaxed text-gray-400 sm:text-base">
        Unreal Engine C++ 기반 게임 시스템 구현 작업물.
        <span class="text-accent/70">태그</span>를 눌러 원하는 카테고리를 필터링하세요.
      </p>
    </div>
  </section>

  <!-- Projects section with filter -->
  <section id="projects-list-section" class="px-4 pb-24 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">

      <!-- Tag filter bar -->
      <div
        class="mb-8 flex items-center gap-2 overflow-x-auto pb-2 scrollbar-thin"
        role="group"
        aria-label="태그 필터"
      >
        <!-- "All" button -->
        <button
          data-filter-tag="all"
          class="filter-btn active-tag shrink-0 rounded-game border border-accent bg-accent px-4 py-2.5 font-mono text-xs font-medium tracking-wide text-white shadow-glow-sm transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-dark"
          aria-pressed="true"
        >
          All
        </button>

        <!-- Tag buttons — generated from content -->
        {allTags.map((tag) => (
          <button
            data-filter-tag={tag}
            class="filter-btn shrink-0 rounded-game border border-dark-300 bg-dark-200 px-4 py-2.5 font-mono text-xs font-medium tracking-wide text-gray-400 transition-all duration-200 hover:border-accent/40 hover:bg-accent/10 hover:text-accent-light focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-dark"
            aria-pressed="false"
          >
            {tag}
          </button>
        ))}
      </div>

      <!-- Project count indicator -->
      <p
        id="projects-count"
        class="mb-6 font-mono text-xs text-gray-600"
        aria-live="polite"
        aria-atomic="true"
      >
        총 <span id="count-number">{sortedProjects.length}</span>개의 프로젝트
      </p>

      <!-- Visually hidden heading for h1→h2→h3 hierarchy -->
      <h2 class="sr-only">프로젝트 목록</h2>

      <!-- Project card grid -->
      <ul
        id="projects-grid"
        class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3"
        aria-label="프로젝트 목록"
      >
        {sortedProjects.map((project) => (
          <li
            data-project-tags={project.data.tags.join(',')}
            class="project-item transition-opacity duration-300"
          >
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              tags={project.data.tags}
              slug={project.id.replace(/\.md$/, '')}
              date={project.data.date}
            />
          </li>
        ))}
      </ul>

      <!-- Empty state — shown when no cards match filter -->
      <div
        id="empty-state"
        class="hidden py-20 text-center"
      >
        <p class="font-mono text-3xl text-dark-300" aria-hidden="true">// 0</p>
        <p class="mt-3 font-mono text-sm text-gray-500">
          해당 태그의 프로젝트가 없습니다.
        </p>
      </div>

    </div>
  </section>
</BaseLayout>

<script>
  // ----------------------------------------------------------------
  // Projects page init — runs on initial load and after View Transitions
  // ----------------------------------------------------------------

  function initProjectsPage() {
    const filterButtons = document.querySelectorAll<HTMLButtonElement>('[data-filter-tag]');
    const projectItems = document.querySelectorAll<HTMLElement>('[data-project-tags]');
    const countNumber = document.getElementById('count-number');
    const emptyState = document.getElementById('empty-state');
    const projectsGrid = document.getElementById('projects-grid');

    // Check user's motion preference
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function applyFilter(tag: string) {
      let visibleCount = 0;

      projectItems.forEach((item) => {
        const tags = (item.dataset.projectTags ?? '').split(',');
        const isVisible = tag === 'all' || tags.includes(tag);

        if (isVisible) {
          item.style.display = '';
          if (!prefersReducedMotion) {
            // Stagger fade-in
            item.style.opacity = '0';
            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
                item.style.transition = 'opacity 0.3s ease';
                item.style.opacity = '1';
              });
            });
          }
          visibleCount++;
        } else {
          item.style.display = 'none';
        }
      });

      // Update count
      if (countNumber) {
        countNumber.textContent = String(visibleCount);
      }

      // Toggle empty state
      if (emptyState && projectsGrid) {
        if (visibleCount === 0) {
          emptyState.classList.remove('hidden');
          projectsGrid.classList.add('hidden');
        } else {
          emptyState.classList.add('hidden');
          projectsGrid.classList.remove('hidden');
        }
      }
    }

    function setActiveButton(activeTag: string) {
      filterButtons.forEach((btn) => {
        const isActive = btn.dataset.filterTag === activeTag;
        btn.setAttribute('aria-pressed', String(isActive));

        if (isActive) {
          btn.classList.add('active-tag', 'border-accent', 'bg-accent', 'text-white', 'shadow-glow-sm');
          btn.classList.remove('border-dark-300', 'bg-dark-200', 'text-gray-400');
        } else {
          btn.classList.remove('active-tag', 'border-accent', 'bg-accent', 'text-white', 'shadow-glow-sm');
          btn.classList.add('border-dark-300', 'bg-dark-200', 'text-gray-400');
        }
      });
    }

    // Attach click handlers
    filterButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const tag = btn.dataset.filterTag ?? 'all';

        setActiveButton(tag);
        applyFilter(tag);

        // Sync URL hash — allows bookmarking / sharing filtered state
        if (tag === 'all') {
          history.replaceState(null, '', location.pathname);
        } else {
          history.replaceState(null, '', `#tag=${encodeURIComponent(tag)}`);
        }
      });
    });

    // Restore filter from URL hash on page load
    const hashParams = new URLSearchParams(location.hash.slice(1));
    const hashTag = hashParams.get('tag');

    if (hashTag) {
      const targetBtn = document.querySelector<HTMLButtonElement>(
        `[data-filter-tag="${CSS.escape(hashTag)}"]`
      );
      if (targetBtn) {
        targetBtn.click();
      }
    }

    // ----------------------------------------------------------------
    // Scroll animation — IntersectionObserver scoped to section
    // ----------------------------------------------------------------
    if (!prefersReducedMotion) {
      const section = document.getElementById('projects-list-section');

      if (section) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                (entry.target as HTMLElement).style.opacity = '1';
                (entry.target as HTMLElement).style.transform = 'translateY(0)';
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );

        // Only animate items that are currently visible (not filtered out)
        projectItems.forEach((item, index) => {
          item.style.opacity = '0';
          item.style.transform = 'translateY(20px)';
          item.style.transition = `opacity 0.4s ease ${index * 60}ms, transform 0.4s ease ${index * 60}ms`;
          observer.observe(item);
        });
      }
    }
  }

  // astro:page-load fires on initial load AND after each View Transition
  document.addEventListener('astro:page-load', initProjectsPage);
</script>

<style>
  /* Hide scrollbar track on filter bar — keep functionality */
  .scrollbar-thin {
    scrollbar-width: thin;
    scrollbar-color: rgba(99, 102, 241, 0.3) transparent;
  }
  .scrollbar-thin::-webkit-scrollbar {
    height: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background-color: rgba(99, 102, 241, 0.3);
    border-radius: 2px;
  }
</style>
