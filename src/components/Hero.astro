---
// Hero section — game developer portfolio landing view
// Staggered CSS animations, terminal aesthetic, no external JS

const skills = ['UE5', 'C++', 'Blueprint', 'Gameplay', 'AI', 'Tools'];
---

<section
  aria-label="히어로 섹션"
  class="relative flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center px-4 py-16 text-center"
>

  <!-- Radial accent glow — decorative background element -->
  <div
    class="pointer-events-none absolute inset-0 flex items-center justify-center"
    aria-hidden="true"
  >
    <div
      class="h-[600px] w-[600px] rounded-full bg-accent/5 blur-[120px]"
    ></div>
  </div>

  <!-- Content stack -->
  <div class="relative z-10 flex flex-col items-center gap-6 sm:gap-8">

    <!-- Terminal-style intro line -->
    <p
      class="hero-intro font-mono text-sm tracking-widest text-accent sm:text-base"
    >
      <span class="text-accent-light opacity-60">&gt;</span>
      <span class="ml-2">system<span class="text-accent-light">.</span>init<span class="text-accent-light">()</span></span>
      <span class="terminal-cursor ml-1 inline-block h-4 w-0.5 translate-y-0.5 bg-accent align-middle" aria-hidden="true"></span>
    </p>

    <!-- Name / primary headline -->
    <div
      class="hero-name flex flex-col items-center gap-2"
    >
      <span class="font-mono text-xs tracking-[0.3em] text-gray-500 uppercase sm:text-sm">
        // portfolio
      </span>
      <h1 class="text-4xl font-bold leading-tight text-gray-100 text-glow sm:text-5xl lg:text-7xl">
        <span class="block text-lg font-medium text-accent-light sm:text-xl lg:text-2xl">허서행</span>
        Game Client Programmer
      </h1>
    </div>

    <!-- Sub headline -->
    <p
      class="hero-sub max-w-lg text-base leading-relaxed text-gray-400 sm:text-lg"
    >
      Unreal Engine C++ 게임 클라이언트 프로그래머. 전투 시스템과 게임플레이를 만듭니다.
    </p>

    <!-- Skill badges -->
    <ul
      class="hero-badges flex flex-wrap justify-center gap-2"
      aria-label="기술 스택"
    >
      {skills.map((skill) => (
        <li>
          <span
            class="inline-block rounded-game border border-accent/30 bg-accent/10 px-3 py-1 font-mono text-xs text-accent-light shadow-glow-sm transition-all duration-300 hover:border-accent/60 hover:bg-accent/20 hover:shadow-glow hover:text-glow-sm sm:text-sm"
          >
            {skill}
          </span>
        </li>
      ))}
    </ul>

    <!-- CTA buttons -->
    <div
      class="hero-cta flex flex-col items-center gap-3 sm:flex-row sm:gap-4"
    >
      <a
        href="/projects"
        class="group relative inline-flex items-center gap-2 rounded-game bg-accent px-6 py-3 font-mono text-sm font-medium text-white shadow-glow transition-all duration-300 hover:bg-accent-dark hover:shadow-glow-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent sm:px-8 sm:text-base"
      >
        <span class="text-accent-light opacity-70 transition-opacity group-hover:opacity-100">&gt;</span>
        프로젝트 보기
      </a>

      <a
        href="/about"
        class="inline-flex items-center gap-2 rounded-game border border-accent/40 bg-transparent px-6 py-3 font-mono text-sm font-medium text-gray-300 transition-all duration-300 hover:border-accent hover:bg-accent/10 hover:text-accent-light hover:shadow-glow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent sm:px-8 sm:text-base"
      >
        About
      </a>
    </div>

  </div>

  <!-- Scroll down indicator -->
  <div
    class="hero-scroll absolute bottom-8 left-1/2 -translate-x-1/2"
    aria-hidden="true"
  >
    <div class="flex flex-col items-center gap-1 text-gray-600">
      <span class="font-mono text-xs tracking-widest">scroll</span>
      <svg
        class="scroll-bounce h-5 w-5 text-accent/60"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>

</section>

<style>
  /* Staggered fade-in-up for hero elements */
  .hero-intro,
  .hero-name,
  .hero-sub,
  .hero-badges,
  .hero-cta,
  .hero-scroll {
    opacity: 0;
    transform: translateY(24px);
    animation: heroFadeUp 0.7s ease-out forwards;
  }

  .hero-intro    { animation-delay: 0s; }
  .hero-name     { animation-delay: 0.15s; }
  .hero-sub      { animation-delay: 0.25s; }
  .hero-badges   { animation-delay: 0.35s; }
  .hero-cta      { animation-delay: 0.45s; }
  .hero-scroll   { animation-delay: 0.6s; }

  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Terminal cursor blink */
  .terminal-cursor {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* Scroll indicator bounce */
  .scroll-bounce {
    animation: scrollBounce 1.8s ease-in-out infinite;
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0);    opacity: 0.5; }
    50%       { transform: translateY(6px);  opacity: 1;   }
  }

  /* Reduced-motion: disable all custom animations */
  @media (prefers-reduced-motion: reduce) {
    .hero-intro,
    .hero-name,
    .hero-sub,
    .hero-badges,
    .hero-cta,
    .hero-scroll {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .terminal-cursor {
      animation: none;
      opacity: 1;
    }

    .scroll-bounce {
      animation: none;
    }
  }
</style>
